# ── TAKMIL backend configuration ──
# Copy to ".env" for local dev. On Railway, set these as service Variables instead.

# PostgreSQL connection. On Railway, add the Postgres plugin and reference it:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
# Locally, point at your own Postgres:
DATABASE_URL=postgresql://user:password@localhost:5432/takmil

# Secret used to sign auth tokens. MUST be changed before deploying.
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-before-deploying

# How long a login stays valid
TOKEN_TTL=7d

# Port (Railway injects its own PORT automatically — leave this for local dev)
PORT=3000

# First admin, created automatically on first run.
SEED_ADMIN_EMAIL=admin@takmil.org
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Administrator

# Set "true" in production (behind HTTPS) so the auth cookie is HTTPS-only.
# Railway serves your app over HTTPS, so set this to true there.
SECURE_COOKIES=false
